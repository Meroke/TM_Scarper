{
  "manifest_version": 3,
  "name": "Taobao Tmall Product Exporter",
  "description": "Export current Taobao or Tmall product information to an Excel-compatible file.",
  "version": "0.4.0",
  "permissions": ["activeTab", "scripting", "downloads", "storage"],
  "host_permissions": [
    "*://*.tmall.com/*",
    "*://detail.tmall.com/*",
    "*://*.alicdn.com/*",
    "*://*.tbcdn.cn/*",
    "*://*.taobao.com/*"
  ],
  "action": {
    "default_title": "Export Taobao/Tmall Product",
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.tmall.com/*",
        "*://detail.tmall.com/*",
        "*://*.taobao.com/*",
        "*://item.taobao.com/*"
      ],
      "js": [
        "src/common/excel.js",
        "src/content/product-extractor.js",
        "src/content/collection-store.js",
        "src/content/clipboard.js",
        "src/content/collector-widget.js",
        "src/content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
