{
  "manifest_version": 3,
  "name": "Tmall Product Exporter",
  "description": "Export current Tmall product information to an Excel-compatible file.",
  "version": "0.3.0",
  "permissions": ["activeTab", "scripting", "downloads", "storage"],
  "host_permissions": [
    "*://*.tmall.com/*",
    "*://detail.tmall.com/*",
    "*://*.alicdn.com/*",
    "*://*.tbcdn.cn/*",
    "*://*.taobao.com/*"
  ],
  "action": {
    "default_title": "Export Tmall Product",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.tmall.com/*", "*://detail.tmall.com/*"],
      "js": [
        "excel.js",
        "product-extractor.js",
        "collection-store.js",
        "clipboard.js",
        "collector-widget.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
